# ZhihuRec V1 environment variables. Copy to .env (or set via $env:NAME in PowerShell) before running.
# Only ZHIHUREC_DATABASE_URL is required for the MySQL-backed runtime.
# All others have working defaults in backend/app/config.py.

# --- Required for MySQL-backed runtime ---
# Without this, MysqlRuntimeRepository is not active and all business endpoints return 503.
# Demo default: mysql+pymysql://root:root@localhost:3306/zhihurec_demo
ZHIHUREC_DATABASE_URL=
ZHIHUREC_MYSQL_CONNECT_TIMEOUT_SECONDS=5
ZHIHUREC_MYSQL_READ_TIMEOUT_SECONDS=10
ZHIHUREC_MYSQL_WRITE_TIMEOUT_SECONDS=10
ZHIHUREC_MYSQL_POOL_MIN_CACHED=1
ZHIHUREC_MYSQL_POOL_MAX_CACHED=5
ZHIHUREC_MYSQL_POOL_MAX_CONNECTIONS=10

# --- App identity ---
ZHIHUREC_APP_NAME=ZhihuRec Backend
ZHIHUREC_APP_VERSION=0.1.0
ZHIHUREC_DEFAULT_DEMO_USER_ID=7248
ZHIHUREC_REQUEST_ID_PREFIX=zhihurec

# --- CORS ---
# Comma-separated. Defaults whitelist the static frontend served by `python -m http.server 5173 -d frontend`.
ZHIHUREC_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
ZHIHUREC_MODEL_DIR=build
ZHIHUREC_DEMO_SEED_DIR=build/demo_world

# --- Behavior score deltas (drive cold-start alpha gating; see brief section 7 / 11) ---
ZHIHUREC_SEARCH_QUERY_BEHAVIOR_DELTA=1.0
ZHIHUREC_RECOMMENDATION_CLICK_BEHAVIOR_DELTA=3.0
ZHIHUREC_SEARCH_RESULT_CLICK_BEHAVIOR_DELTA=5.0

# --- Profile topic update parameters ---
ZHIHUREC_PROFILE_TOPIC_DECAY=0.92
ZHIHUREC_RECOMMENDATION_CLICK_TOPIC_DELTA=0.08
ZHIHUREC_SEARCH_RESULT_CLICK_TOPIC_DELTA=0.12
ZHIHUREC_SEARCH_RESULT_OVERLAP_TOPIC_DELTA=0.2

# --- Cold-start mixing (alpha = floor + (score / (score + scale)) * (ceiling - floor)) ---
ZHIHUREC_COLD_START_ALPHA_FLOOR=0.1
ZHIHUREC_COLD_START_ALPHA_CEILING=0.95
ZHIHUREC_COLD_START_BEHAVIOR_SCORE_SCALE=30.0
ZHIHUREC_COLD_START_DEFAULT_SEED_KEY=cold_start_default

# --- V2 Kafka event stream (optional; V1 default is sync_mysql) ---
# sync_mysql: current synchronous MySQL event/profile updates.
# kafka_dual_write: keep sync MySQL behavior and also publish Kafka events.
# kafka_async: stage raw events in MySQL Outbox; run both workers to update profiles.
ZHIHUREC_EVENT_MODE=sync_mysql
ZHIHUREC_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
ZHIHUREC_KAFKA_CLIENT_ID=zhihurec-api
ZHIHUREC_KAFKA_PROFILE_GROUP_ID=zhihurec-profile-consumer
ZHIHUREC_KAFKA_RAW_EVENTS_TOPIC=zhihurec.events.raw
ZHIHUREC_KAFKA_TRAINING_TOPIC=zhihurec.training.interactions
ZHIHUREC_KAFKA_DLQ_TOPIC=zhihurec.events.dlq
ZHIHUREC_KAFKA_PRODUCER_LINGER_MS=5
ZHIHUREC_KAFKA_PRODUCER_FLUSH_TIMEOUT_SECONDS=10
ZHIHUREC_KAFKA_CONSUMER_MAX_RETRIES=5
ZHIHUREC_KAFKA_CONSUMER_RETRY_BACKOFF_SECONDS=1
ZHIHUREC_OUTBOX_BATCH_SIZE=100
ZHIHUREC_OUTBOX_MAX_ATTEMPTS=10
ZHIHUREC_OUTBOX_POLL_INTERVAL_SECONDS=1
ZHIHUREC_OUTBOX_STALE_AFTER_SECONDS=60

# --- Synthetic sponsored-candidate lane ---
ZHIHUREC_SPONSORED_ENABLED=1
ZHIHUREC_SPONSORED_SLOTS=3,8
ZHIHUREC_SPONSORED_PACING_HEADROOM_SECONDS=3600

# --- Health and metrics ---
ZHIHUREC_READINESS_TIMEOUT_SECONDS=2
ZHIHUREC_READINESS_OUTBOX_BACKLOG_LIMIT=10000
ZHIHUREC_READINESS_WORKER_HEARTBEAT_MAX_AGE_SECONDS=15
ZHIHUREC_READINESS_OUTBOX_OLDEST_PENDING_MAX_AGE_SECONDS=30
ZHIHUREC_READINESS_CONSUMER_LAG_LIMIT=1000
ZHIHUREC_CONSUMER_METRICS_PORT=9101
ZHIHUREC_OUTBOX_METRICS_PORT=9102
