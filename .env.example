# NewsIntentRec environment variables. Copy to .env before running.
# NEWSREC_DATABASE_URL is required for MySQL-backed business endpoints.
# ZHIHUREC_* aliases remain supported for one migration cycle and emit warnings.

# Public MIND acquisition. Accept the Microsoft Research License and the selected
# dataset-host terms before setting a local read token. Never commit this token.
HF_TOKEN=

# Runtime and MySQL
NEWSREC_DATABASE_URL=
NEWSREC_MYSQL_CONNECT_TIMEOUT_SECONDS=5
NEWSREC_MYSQL_READ_TIMEOUT_SECONDS=10
NEWSREC_MYSQL_WRITE_TIMEOUT_SECONDS=10
NEWSREC_MYSQL_POOL_MIN_CACHED=1
NEWSREC_MYSQL_POOL_MAX_CACHED=5
NEWSREC_MYSQL_POOL_MAX_CONNECTIONS=10

# Product identity and local assets
NEWSREC_APP_NAME=NewsIntentRec Backend
NEWSREC_APP_VERSION=0.1.0
NEWSREC_DEMO_SEED_DIR=build/mind_demo_world
NEWSREC_REQUEST_ID_PREFIX=newsrec
NEWSREC_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
NEWSREC_MODEL_DIR=build/mind_models
VITE_NEWSREC_API_BASE=http://127.0.0.1:8000

# Profile and ranking behavior
NEWSREC_SEARCH_QUERY_BEHAVIOR_DELTA=1.0
NEWSREC_RECOMMENDATION_CLICK_BEHAVIOR_DELTA=3.0
NEWSREC_SEARCH_RESULT_CLICK_BEHAVIOR_DELTA=5.0
NEWSREC_PROFILE_TOPIC_DECAY=0.92
NEWSREC_RECOMMENDATION_CLICK_TOPIC_DELTA=0.08
NEWSREC_SEARCH_RESULT_CLICK_TOPIC_DELTA=0.12
NEWSREC_SEARCH_RESULT_OVERLAP_TOPIC_DELTA=0.2
NEWSREC_COLD_START_ALPHA_FLOOR=0.1
NEWSREC_COLD_START_ALPHA_CEILING=0.95
NEWSREC_COLD_START_BEHAVIOR_SCORE_SCALE=30.0
NEWSREC_COLD_START_DEFAULT_SEED_KEY=cold_start_default
NEWSREC_ALS_RECALL_TOP_K=200
NEWSREC_ALS_RECALL_ENABLED=1

# Event stream
NEWSREC_EVENT_MODE=sync_mysql
NEWSREC_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
NEWSREC_KAFKA_CLIENT_ID=newsrec-api
NEWSREC_KAFKA_PROFILE_GROUP_ID=newsrec-profile-consumer
NEWSREC_KAFKA_RAW_EVENTS_TOPIC=newsrec.events.raw
NEWSREC_KAFKA_TRAINING_TOPIC=newsrec.training.interactions
NEWSREC_KAFKA_DLQ_TOPIC=newsrec.events.dlq
NEWSREC_KAFKA_PRODUCER_LINGER_MS=5
NEWSREC_KAFKA_PRODUCER_FLUSH_TIMEOUT_SECONDS=10
NEWSREC_KAFKA_CONSUMER_MAX_RETRIES=5
NEWSREC_KAFKA_CONSUMER_RETRY_BACKOFF_SECONDS=1
NEWSREC_OUTBOX_BATCH_SIZE=100
NEWSREC_OUTBOX_MAX_ATTEMPTS=10
NEWSREC_OUTBOX_POLL_INTERVAL_SECONDS=1
NEWSREC_OUTBOX_STALE_AFTER_SECONDS=60

# Sponsored demo lane
NEWSREC_SPONSORED_ENABLED=1
NEWSREC_SPONSORED_SLOTS=3,8
NEWSREC_SPONSORED_PACING_HEADROOM_SECONDS=3600

# Health and metrics
NEWSREC_READINESS_TIMEOUT_SECONDS=2
NEWSREC_READINESS_OUTBOX_BACKLOG_LIMIT=10000
NEWSREC_READINESS_WORKER_HEARTBEAT_MAX_AGE_SECONDS=15
NEWSREC_READINESS_OUTBOX_OLDEST_PENDING_MAX_AGE_SECONDS=30
NEWSREC_READINESS_CONSUMER_LAG_LIMIT=1000
NEWSREC_CONSUMER_METRICS_PORT=9101
NEWSREC_OUTBOX_METRICS_PORT=9102
